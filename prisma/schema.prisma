// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH MODELS (NextAuth.js)
// ============================================

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  password          String? // Nullable for OAuth users
  role              String             @default("USER")
  isVerified        Boolean            @default(false)
  accounts          Account[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// YOUR APP MODELS (Add your models below)
// ============================================

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String // email or IP
  action     String // "resend-otp" or "forgot-password"
  count      Int      @default(1)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, action])
  @@index([identifier, action])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
}

// ============================================
// WORK4U APP MODELS
// ============================================

model Task {
  id             String   @id @default(cuid())
  category       String
  description    String   @db.Text
  startDate      DateTime
  endDate        DateTime
  hoursPerDay    Int
  location       String
  address        String?
  budget         Float
  budgetType     String   @default("Per Hour") // "Per Hour" | "Per Day" | "Fixed"
  mobileNumber   String
  userEmail      String
  userName       String
  taskerEmail    String   @default("Not Assigned")
  status         String   @default("OPEN") // "OPEN" | "ASSIGNED" | "COMPLETED" | "PAID"
  gender         String?
  numberOfPeople Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userEmail])
  @@index([status])
  @@index([category])
  @@index([location])
}

model Tasker {
  id          String   @id @default(cuid())
  name        String
  mobile      String
  location    String
  residence   String // "Room" | "Hostel"
  college     String
  course      String
  yearOfStudy String // "First" | "Second" | "Third" | "Fourth"
  skills      String[] // Array of skill strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([location])
  @@index([mobile])
}
